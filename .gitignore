# dependencies
/node_modules
/.pnp
.pnp.js

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# misc
.DS_Store
tsconfig.tsbuildinfo
*.log

# ---------------------------------------------------------------------------
# SECRETS & SENSITIVE DATA — never commit real credentials
# ---------------------------------------------------------------------------

# env files (real values live in .env.local; only .env.example is committed)
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
# safety net: catch any stray .env* except the template
.env*
!.env.example

# private keys / certificates
*.pem
*.key
*.crt
*.cer
*.der
*.p12
*.pfx
*.keystore
*.jks

# credential / secret files
*secret*
*secrets*
*.secret
credentials.json
service-account*.json
gha-creds-*.json
*-credentials.json
.npmrc
.netrc

# Supabase CLI local state (project refs, pooler urls, linked-project, etc.)
supabase/.temp/
supabase/.branches/
.supabase/

# ---------------------------------------------------------------------------

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# editor
.vscode/*
!.vscode/extensions.json

# Claude Code local (machine-specific) settings — keep shared settings.json
.claude/settings.local.json

.vercel

# ---------------------------------------------------------------------------
# LOCAL DEV / TEST DATA — not part of the production build, never deploy
# ---------------------------------------------------------------------------
# Test-account / sample-data seeders (create accounts that must not exist in
# the live database). Run locally only.
/scripts/seed-*.mjs

# Throwaway UI screenshots / PDFs from local preview scaffolding
/screenshots/

# Claude / internal handoff notes — planning docs, not for the public repo
*_HANDOFF.md
