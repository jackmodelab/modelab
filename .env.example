# Copy to .env.local and fill in real values. NEVER commit .env.local.

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="MODE Lab"

# --- Supabase (Database + Auth + Storage) ---
# From your project at https://supabase.com  →  Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=

# --- Test account (used by `npm run seed:test`, LOCAL DEV ONLY) ---
# No default password — set your own. The seed script refuses to run unless
# both are set AND the Supabase URL is a local instance.
TEST_CLIENT_EMAIL=client@modelab.test
TEST_CLIENT_PASSWORD=
TEST_STAFF_EMAIL=jack@modelab.test
TEST_STAFF_PASSWORD=

# --- Google Calendar (per-coach booking sync) ---
# Google Cloud Console → APIs & Services:
#   1. Enable the "Google Calendar API".
#   2. Create an OAuth 2.0 Client ID of type "Web application".
#   3. Add this Authorized redirect URI:  <NEXT_PUBLIC_SITE_URL>/api/google/oauth/callback
#      (e.g. http://localhost:3000/api/google/oauth/callback and the prod URL).
# Coaches then click "Connect Google Calendar" in the portal (Availability page).
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# --- Coming in later slices ---
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
