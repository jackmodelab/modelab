# Copy to .env.local and fill in real values. NEVER commit .env.local.

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="MODE Lab"

# --- Supabase (Database + Auth + Storage) ---
# From your project at https://supabase.com  →  Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=

# --- Test account (used by `npm run seed:test`) ---
TEST_CLIENT_EMAIL=client@modelab.test
TEST_CLIENT_PASSWORD=ModeLab!2026
TEST_STAFF_EMAIL=jack@modelab.test
TEST_STAFF_PASSWORD=ModeLab!2026

